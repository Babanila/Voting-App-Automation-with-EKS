*.pyc
project.lock.json
bin/
obj/
.vs/
.vscode/
.DS_STORE
node_modules/

.env
!*.env.example
example*

# SSH Keys (SSH & Ansible Authentication)
*.pem
*.key

# System files
.DS_Store
*.DS_Store

# Generated files that contains .env parameters
backend.json
backend.tf

# Local provider/module cache & backend config
.terraform/
**/.terraform/*

*.lock.hcl
!.terraform.lock.hcl

# State files (contain sensitive data & are environment-specific)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Variable files (often contain secrets or env-specific values)
*.tfvars
*.tfvars.json
!*.example.tfvars
!*.example.tfvars.json

# Saved plan files (binary, ephemeral)
tfplan
*.tfplan


# Local overrides (used for temporary debugging/testing)
*_override.tf
*_override.tf.json

# CLI config (user/machine-specific)
.terraformrc
terraform.rc

# Logs
*.log
